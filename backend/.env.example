# Gemini API Configuration
GEMINI_API_KEY=<your-gemini-api-key>

# Flask Configuration
FLASK_PORT=5000
UPLOAD_DIR=uploads
CLIPS_DIR=generated_clips

# Email Configuration (for notifications)
SENDER_EMAIL=<your-email@gmail.com>
SENDER_PASSWORD=<your-app-specific-password>

# AWS Credentials
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>
AWS_REGION=ap-south-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# S3 Storage
AWS_S3_BUCKET=<your-s3-bucket-name>

# DynamoDB Tables 
DYNAMO_USERS_TABLE=ClipSense-Users
DYNAMO_PROJECTS_TABLE=ClipSense-Projects

# Admin Configuration
ADMIN_EMAIL=<your-admin-email@gmail.com>

# SQS Queue (will be generated by setup-sqs.ps1)
SQS_QUEUE_URL=<your-sqs-queue-url>

# Deployment Configuration
JWT_SECRET_KEY=<your-jwt-secret-key>
GITHUB_REPO=<your-username>/<your-repo-name>
EC2_KEY_NAME=clipsense-worker-key

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=<your-google-client-id>

# Lambda Function ARN (will be generated by setup-lambda.ps1)
LAMBDA_FUNCTION_ARN=<your-lambda-function-arn>
